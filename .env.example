# --- Discord ---
# Bot token from https://discord.com/developers/applications
DISCORD_TOKEN=

# Optional: restrict slash commands to a single guild for instant registration
# (leave blank to register globally, which can take up to ~1 hour to appear).
DISCORD_GUILD_ID=

# --- Seerr ---
# Base URL of your Seerr instance, e.g. http://localhost:5055 or https://seerr.example.com
SEERR_URL=http://localhost:5055
# Seerr API key (Settings -> General -> API Key). Must belong to an admin user.
SEERR_API_KEY=

# --- Behaviour ---
# Require users to link a Plex account before their first request (recommended: true).
REQUIRE_LINKING=true
# Fallback Seerr user id used when linking is disabled or no link is found.
# Leave blank to submit with no explicit user (Seerr attributes it to the API key owner).
DEFAULT_SEERR_USER_ID=

# Path to the SQLite database storing Discord<->Seerr links.
DATABASE_PATH=data/vaultrequestrr.sqlite3

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# --- Notifications ---
# How often (seconds) to reconcile request status with Seerr. With the webhook
# configured (below) this is just a slow backstop, so 600 is plenty; 0 disables it.
POLL_INTERVAL_SECONDS=600
# DM the requester when their media becomes available / is declined.
NOTIFY_ON_AVAILABLE=true
NOTIFY_ON_DECLINED=true
# DM the reporter when their reported issue is marked resolved.
NOTIFY_ON_ISSUE_RESOLVED=true

# --- Admin dashboard ---
# Set a password to enable the web dashboard (left blank = dashboard disabled).
WEB_PASSWORD=
# Port the dashboard listens on.
WEB_PORT=5056

# --- Seerr webhook (instant notifications) ---
# Shared secret for the inbound webhook. When set, point Seerr's Webhook agent at
#   http://<host>:<WEB_PORT>/webhook/seerr?token=<WEBHOOK_SECRET>
# so request/issue updates are delivered in seconds instead of waiting for a poll.
# Leave blank to disable the endpoint (it returns 401 until a secret is set).
WEBHOOK_SECRET=
