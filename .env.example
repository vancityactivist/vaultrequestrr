# --- Discord ---
# Bot token from https://discord.com/developers/applications
DISCORD_TOKEN=

# Optional: restrict slash commands to a single guild for instant registration
# (leave blank to register globally, which can take up to ~1 hour to appear).
DISCORD_GUILD_ID=

# --- Seerr ---
# Base URL of your Seerr instance, e.g. http://localhost:5055 or https://seerr.example.com
SEERR_URL=http://localhost:5055
# Seerr API key (Settings -> General -> API Key). Must belong to an admin user.
SEERR_API_KEY=

# --- Behaviour ---
# Require users to link a Plex account before their first request (recommended: true).
REQUIRE_LINKING=true
# Fallback Seerr user id used when linking is disabled or no link is found.
# Leave blank to submit with no explicit user (Seerr attributes it to the API key owner).
DEFAULT_SEERR_USER_ID=

# Path to the SQLite database storing Discord<->Seerr links.
DATABASE_PATH=data/vaultrequestrr.sqlite3

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# --- Notifications ---
# Backstop poll interval (seconds). The poller adapts: with no webhook configured
# it polls every 2 min so polling-only setups stay near-real-time; once a webhook
# (below) is set it relaxes to this value. 0 disables polling entirely.
POLL_INTERVAL_SECONDS=600
# DM the requester when their media becomes available / is declined.
NOTIFY_ON_AVAILABLE=true
NOTIFY_ON_DECLINED=true
# DM the reporter when their reported issue is marked resolved.
NOTIFY_ON_ISSUE_RESOLVED=true

# --- Admin dashboard ---
# Set a password to enable the web dashboard (left blank = dashboard disabled).
WEB_PASSWORD=
# Port the dashboard listens on.
WEB_PORT=5056

# --- Seerr webhook (instant notifications) ---
# Shared secret for the inbound webhook. When set, point Seerr's Webhook agent at
#   http://<host>:<WEB_PORT>/webhook/seerr?token=<WEBHOOK_SECRET>
# so request/issue updates are delivered in seconds instead of waiting for a poll.
# Leave blank to disable the endpoint (it returns 401 until a secret is set).
WEBHOOK_SECRET=

# --- Approvals ---
# Requests from users without Seerr's auto-approve permission wait for an admin.
# Comma-separated Discord user ids that may approve/decline and get DM'd about
# pending requests. Manageable from the dashboard too (this is the first-run default).
ADMIN_DISCORD_IDS=
# Optional Discord channel id to also post pending requests to (with Approve/Decline
# buttons). Leave blank to only DM the admins.
APPROVALS_CHANNEL_ID=

# --- Anime routing (the /anime command) ---
# Route /anime requests to dedicated Sonarr/Radarr instances. The *_SERVER_ID is the
# Seerr instance id (Seerr -> Settings -> Services, also listed on the dashboard's
# Settings page). Setting a server id is what enables /anime for that media type:
# series go to Sonarr, anime films to Radarr. All values are manageable from the
# dashboard too (these env vars are only the first-run default).
ANIME_SONARR_SERVER_ID=
ANIME_RADARR_SERVER_ID=
# Optional advanced overrides. Leave blank to let Seerr apply the target instance's own
# anime quality profile / root folder (and, for series, the anime series type). Setting
# these forces a specific profile/folder and bypasses Seerr's anime-aware selection.
ANIME_SONARR_PROFILE_ID=
ANIME_SONARR_ROOT_FOLDER=
ANIME_RADARR_PROFILE_ID=
ANIME_RADARR_ROOT_FOLDER=
